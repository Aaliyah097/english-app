# Copy to .env.local and fill in. The serverless function reads these at
# request time — they are never bundled into the browser.

# Required: DeepSeek API key. Server-side only.
DEEPSEEK_API_KEY=

# Optional: model name. Defaults to 'deepseek-chat'.
# DEEPSEEK_MODEL=deepseek-chat

# Optional: provider base URL. Defaults to 'https://api.deepseek.com/v1'.
# Override only if pointing at a different OpenAI-compatible provider.
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
